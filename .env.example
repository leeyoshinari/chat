# 应用访问密码
ACCESS_PASSWORD=your-password-here

# 历史消息限制数量
HISTORY_LIMIT=30

# ============================================
# 模型提供商配置
# 
# 配置说明：
# - XXX_ENABLED: 是否启用该提供商
# - XXX_BASE_URL: API 地址
# - XXX_API_KEY: API 密钥
# - XXX_MODELS: 模型列表，格式：model-id=显示名称<能力>,...
# 
# 能力标识：
# - fc: 支持函数/工具调用
# - vision: 支持图片输入
# - file: 支持文件输入
# - reasoning: 支持推理思考模式
# - imageOutput: 支持图片生成
# - tts: 支持文字转语音
# - asr: 支持语音转语音
# - stt: 支持语音转文字
# - search: 支持内置联网搜索
# ============================================

# OpenAI 配置
OPENAI_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODELS=gpt-5-mini=GPT-5-mini<fc:reasoning>

# Google (Gemini) 配置
GOOGLE_ENABLED=false
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODELS=gemini-2.5-flash-preview-tts=Gemini 2.5 Flash TTS<tts>,gemini-3-flash-preview=Gemini 3.0 Flash<fc:vision:search:file:reasoning>,gemini-3.1-flash-lite-preview=Gemini 3.1 Flash-Lite<fc:vision:search:file:reasoning>

# Anthropic (Claude) 配置, 代码自动生成，暂未调试这个链路
ANTHROPIC_ENABLED=false
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODELS=claude

# DeepSeek 配置
DEEPSEEK_ENABLED=false
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODELS=deepseek-r1=DeepSeek-R1<reasoning>,deepseek-v3-2-exp=DeepSeek-V3<fc>

# 通义千问 (Qwen) 配置, 代码自动生成，暂未调试这个链路
QWEN_ENABLED=false
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your-qwen-api-key
QWEN_MODELS=qwen

# Cloudflare Workers AI 配置
CLOUDFLARE_ENABLED=false
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4/accounts/{account_id}/ai/v1
CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_MODELS=@cf/black-forest-labs/flux-2-klein-9b=Flux-2-Klein-9B<imageOutput:vision>,@cf/openai/whisper-large-v3-turbo=Whisper-Large-v3-Turbo<stt>

# ============================================
# 工具配置
# ============================================

# 联网搜索工具
WEB_SEARCH_ENABLED=false
# 搜索 API 类型: google 或 serper
SEARCH_API_TYPE=serper
# Google Search API 配置
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id
# Serper API 配置
SERPER_API_KEY=your-serper-api-key
# 联网搜索关键词智能提取
# openai | deepseek | cloudflare | google
KEYWORD_EXTRACTOR_PROVIDER=cloudflare
KEYWORD_EXTRACTOR_MODEL=@cf/zai-org/glm-4.7-flash

# 代码解释器工具, 代码自动生成，暂未调试这个链路
TOOL_CODE_INTERPRETER_ENABLED=false
